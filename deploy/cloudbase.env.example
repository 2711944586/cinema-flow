# Copy this file to deploy/cloudbase.env.local and fill your own values.
# Do not commit deploy/cloudbase.env.local.

# Tencent Cloud API credential.
# Get it from: https://console.cloud.tencent.com/cam/capi
# You can leave both fields empty and the deploy script will run browser/device login.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# Optional. Only needed when using temporary STS credentials.
TENCENT_TOKEN=

# CloudBase environment.
# The id below comes from the value you provided.
CLOUDBASE_ENV_ID=constantine-d3gjhwmtz0336c36a
CLOUDBASE_REGION=ap-shanghai
CLOUDBASE_ENV_ALIAS=cinemaflow
CLOUDBASE_PACKAGE=baas_personal
CLOUDBASE_DURATION=1

# Set true only when you want the script to create a new CloudBase environment.
# If CLOUDBASE_ENV_ID is filled, the script deploys to that existing environment.
CLOUDBASE_CREATE_ENV=false

# Backend HTTP function.
CLOUDBASE_FUNCTION_NAME=cinemaflow-api
CLOUDBASE_FUNCTION_RUNTIME=Python3.10
CLOUDBASE_FUNCTION_PATH=/api
CLOUDBASE_FUNCTION_DEPLOY_MODE=zip
CLOUDBASE_FUNCTION_MEMORY=512
CLOUDBASE_FUNCTION_TIMEOUT=15

# Set true when the function is already healthy and you only need to rebuild/upload the frontend.
CLOUDBASE_SKIP_FUNCTION_DEPLOY=false

# API URL injected into Angular runtime-config.js.
# If empty, the script uses: https://<CLOUDBASE_ENV_ID>.service.tcloudbase.com/api
CLOUDBASE_API_BASE_URL=

# CORS origin for Flask API.
# Use * for first deploy. After you know the static hosting domain, replace it with that domain.
CLOUDBASE_CORS_ORIGINS=*

# Database schema deployment.
# If true, the script tries to execute docs/database/cloudbase-mysql-schema.sql.
# This requires a CloudBase MySQL instance already enabled in the environment.
CLOUDBASE_DEPLOY_DATABASE_SCHEMA=false

# Post-deploy checks.
CLOUDBASE_SKIP_HEALTH_CHECK=false
